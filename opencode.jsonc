{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "godot": {
      "type": "local",
      "command": ["npx", "@coding-solo/godot-mcp"],
      "enabled": true,
      "environment": {
        "GODOT_PATH": "/Applications/Godot.app/Contents/MacOS/Godot",
        "DEBUG": "true",
      },
    },
    "godot-docs": {
      "type": "local",
      "command": ["npx", "mcp-remote", "http://localhost:8787/mcp"],
      "enabled": true,
    },
  },
}
