[gd_scene format=3]

[ext_resource type="Script" path="res://ui/main_menu.gd" id="1_menu"]

[node name="MainMenu" type="CanvasLayer"]
script = ExtResource("1_menu")

[node name="CenterContainer" type="CenterContainer" parent="."]
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0

[node name="VBox" type="VBoxContainer" parent="CenterContainer"]
layout_mode = 2
alignment = 1

[node name="Title" type="Label" parent="CenterContainer/VBox"]
layout_mode = 2
horizontal_alignment = 1
theme_override_font_sizes/font_size = 48
text = "RGB Defense"

[node name="Spacer" type="Control" parent="CenterContainer/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(0, 32)

[node name="StartBtn" type="Button" parent="CenterContainer/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(200, 50)
text = "Start Game"

[node name="SettingsBtn" type="Button" parent="CenterContainer/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(200, 50)
text = "Settings"

[node name="QuitBtn" type="Button" parent="CenterContainer/VBox"]
layout_mode = 2
custom_minimum_size = Vector2(200, 50)
text = "Quit"

[connection signal="pressed" from="CenterContainer/VBox/StartBtn" to="." method="_on_start_pressed"]
[connection signal="pressed" from="CenterContainer/VBox/SettingsBtn" to="." method="_on_settings_pressed"]
[connection signal="pressed" from="CenterContainer/VBox/QuitBtn" to="." method="_on_quit_pressed"]
